# Copy this file to `.env.local` and fill in your values.
# `.env.local` is gitignored and is not loaded into Cursor MCP automatically;
# use it for app/tooling that reads env vars (e.g. Vite with VITE_* vars).

# GitHub Personal Access Token (optional — for scripts or if your tooling reads this)
# Create a token: https://github.com/settings/personal-access-tokens/new
GITHUB_PERSONAL_ACCESS_TOKEN=
